<!DOCTYPE html>
<html id="htmlRoot" lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= botName || 'DENTSU MD V9' %></title>
  
  <!-- Styles intégrés (autonome) -->
  <style>
    /* ── RESET ET BASE ── */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: #0a0a0f;
      color: #e0e0e0;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    /* ── OVERLAY LANGUE ── */
    #langOverlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(10, 10, 15, 0.95);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .lang-overlay-content {
      background: #1a1a2e;
      padding: 30px 20px;
      border-radius: 20px;
      max-width: 600px;
      width: 90%;
      border: 1px solid #2a2a4e;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
      max-height: 90vh;
      overflow-y: auto;
    }

    .lang-overlay-content h2 {
      text-align: center;
      font-size: 1.3rem;
      margin-bottom: 25px;
      color: #fff;
    }

    .lang-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 8px;
    }

    .flag-mini {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 10px 6px;
      background: #2a2a4e;
      border: 2px solid transparent;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.3s ease;
      color: #ccc;
      font-size: 0.75rem;
      font-weight: 500;
      font-family: inherit;
      min-height: 70px;
    }

    .flag-mini:hover {
      background: #3a3a6e;
      transform: translateY(-2px);
    }

    .flag-mini.active-flag {
      border-color: #00ff88;
      background: #1a3a2e;
      color: #00ff88;
    }

    .flag-mini .flag-emoji {
      font-size: 32px;
      line-height: 1.2;
    }

    .flag-mini .flag-label {
      font-size: 0.7rem;
      text-align: center;
      word-break: break-word;
    }

    /* ── CONTENEUR PRINCIPAL ── */
    .container {
      max-width: 600px;
      width: 100%;
      margin: 0 auto;
    }

    /* ── EN-TÊTE ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
      border-bottom: 1px solid #1a1a2e;
      margin-bottom: 30px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .bot-icon { font-size: 2rem; }

    .header h1 {
      font-size: 1.2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #00ff88, #00ccff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .badge {
      font-size: 0.65rem;
      padding: 4px 12px;
      background: #1a1a2e;
      border-radius: 20px;
      color: #888;
      border: 1px solid #2a2a4e;
      white-space: nowrap;
    }

    /* ── CARTES ── */
    .card {
      background: #12121f;
      border-radius: 16px;
      padding: 25px 20px;
      margin-bottom: 20px;
      border: 1px solid #1a1a2e;
    }

    .connect-card h2 {
      font-size: 1.3rem;
      margin-bottom: 8px;
      color: #fff;
    }

    .subtitle {
      color: #888;
      font-size: 0.9rem;
      margin-bottom: 20px;
      line-height: 1.4;
    }

    /* ── FORMULAIRE ── */
    .input-group {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .input-group input {
      flex: 1;
      min-width: 150px;
      padding: 14px 16px;
      background: #1a1a2e;
      border: 2px solid #2a2a4e;
      border-radius: 12px;
      color: #fff;
      font-size: 1rem;
      transition: border-color 0.3s ease;
      outline: none;
      font-family: inherit;
    }

    .input-group input:focus { border-color: #00ff88; }
    .input-group input::placeholder { color: #555; }
    .input-group input:disabled { opacity: 0.5; }

    .input-group button {
      padding: 14px 20px;
      background: linear-gradient(135deg, #00ff88, #00cc66);
      border: none;
      border-radius: 12px;
      color: #0a0a0f;
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.3s ease;
      white-space: nowrap;
      font-family: inherit;
      min-width: 120px;
    }

    .input-group button:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(0, 255, 136, 0.3);
    }

    .input-group button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .hint {
      font-size: 0.8rem;
      color: #666;
      margin-top: 6px;
      line-height: 1.4;
    }

    .hint strong { color: #00ff88; }

    /* ── SPINNER ── */
    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid #0a0a0f;
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      vertical-align: middle;
      margin-right: 8px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── RÉSULTAT ── */
    .result {
      padding: 14px 16px;
      border-radius: 12px;
      margin-top: 18px;
      font-weight: 500;
      display: none;
      font-size: 0.95rem;
    }

    .result.success {
      background: #0a2a1a;
      border: 1px solid #00ff8844;
      color: #00ff88;
      display: block;
    }

    .result.error {
      background: #2a0a0a;
      border: 1px solid #ff444444;
      color: #ff6666;
      display: block;
    }

    /* ── CODE ── */
    .code-container {
      margin-top: 18px;
      padding: 18px;
      background: #0a0a15;
      border-radius: 12px;
      border: 1px solid #1a1a2e;
    }

    .code-container > p {
      color: #888;
      font-size: 0.85rem;
      margin-bottom: 10px;
    }

    .code-box {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .code-box #codeValue {
      font-size: 1.8rem;
      font-weight: 700;
      font-family: 'Courier New', monospace;
      color: #00ff88;
      letter-spacing: 3px;
      word-break: break-all;
    }

    .code-box button {
      padding: 8px 16px;
      background: #1a1a2e;
      border: 1px solid #2a2a4e;
      border-radius: 8px;
      color: #ccc;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 0.8rem;
      font-family: inherit;
      white-space: nowrap;
    }

    .code-box button:hover {
      background: #2a2a4e;
      border-color: #00ff88;
      color: #fff;
    }

    .warning {
      margin-top: 10px;
      font-size: 0.8rem;
      color: #ffaa44;
    }

    .warning strong { color: #ff6644; }

    /* ── ÉTAPES ── */
    .steps-container {
      margin-top: 18px;
      padding: 18px;
      background: #0a0a15;
      border-radius: 12px;
      border: 1px solid #1a1a2e;
    }

    .steps-title {
      color: #888;
      font-size: 0.85rem;
      margin-bottom: 10px;
    }

    #stepsList {
      list-style: none;
      padding: 0;
    }

    #stepsList li {
      padding: 6px 0 6px 24px;
      position: relative;
      color: #ccc;
      font-size: 0.85rem;
      line-height: 1.5;
      border-bottom: 1px solid #1a1a2e;
    }

    #stepsList li:last-child { border-bottom: none; }

    #stepsList li::before {
      content: "▸";
      position: absolute;
      left: 0;
      color: #00ff88;
      font-weight: 700;
    }

    #stepsList li strong { color: #fff; }

    #stepsList li strong#codeInSteps {
      color: #00ff88;
      font-size: 1rem;
      padding: 2px 8px;
      background: #0a0a15;
      border-radius: 4px;
    }

    /* ── LIENS SOCIAUX ── */
    .social-card { padding: 18px 20px; }

    .social-links {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .social-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background: #1a1a2e;
      border-radius: 12px;
      color: #ccc;
      text-decoration: none;
      transition: all 0.3s ease;
      font-size: 0.85rem;
      border: 1px solid #2a2a4e;
      font-family: inherit;
    }

    .social-btn:hover {
      background: #2a2a4e;
      transform: translateY(-2px);
      border-color: #00ff8844;
    }

    .social-btn.channel:hover { border-color: #25D366; }
    .social-btn.group:hover { border-color: #34B7F1; }
    .social-btn.telegram:hover { border-color: #0088cc; }

    /* ── PIED DE PAGE ── */
    .footer {
      text-align: center;
      padding: 18px 0;
      color: #444;
      font-size: 0.75rem;
      border-top: 1px solid #1a1a2e;
      margin-top: 10px;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .lang-grid { grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); }
      .flag-mini { padding: 8px 4px; font-size: 0.65rem; min-height: 60px; }
      .flag-mini .flag-emoji { font-size: 28px; }
      .card { padding: 18px 14px; }
      
      .input-group { flex-direction: column; }
      .input-group button { width: 100%; justify-content: center; }
      .input-group input { min-width: unset; }
      
      .code-box { flex-direction: column; align-items: stretch; text-align: center; }
      .code-box #codeValue { font-size: 1.4rem; letter-spacing: 2px; }
      .code-box button { width: 100%; justify-content: center; }
      
      .header h1 { font-size: 1rem; }
      .badge { font-size: 0.55rem; padding: 2px 8px; }
      .social-btn { font-size: 0.75rem; padding: 6px 12px; }
    }

    @media (max-width: 400px) {
      .lang-grid { grid-template-columns: repeat(auto-fill, minmax(70px, 1fr)); }
      .flag-mini .flag-emoji { font-size: 24px; }
      .flag-mini .flag-label { font-size: 0.6rem; }
    }

    /* Scrollbar personnalisée */
    .lang-overlay-content::-webkit-scrollbar { width: 4px; }
    .lang-overlay-content::-webkit-scrollbar-track { background: transparent; }
    .lang-overlay-content::-webkit-scrollbar-thumb { background: #00ff8844; border-radius: 10px; }
  </style>
</head>
<body>

  <!-- ═══ OVERLAY DE SÉLECTION DE LANGUE ═══ -->
  <div id="langOverlay">
    <div class="lang-overlay-content">
      <h2>🌍 Choose your language</h2>
      <div class="lang-grid" id="langGrid">
        <button class="flag-mini" data-lang="fr" onclick="setLang('fr')">
          <span class="flag-emoji">🇫🇷</span>
          <span class="flag-label">Français</span>
        </button>
        <button class="flag-mini" data-lang="en" onclick="setLang('en')">
          <span class="flag-emoji">🇬🇧</span>
          <span class="flag-label">English</span>
        </button>
        <button class="flag-mini" data-lang="es" onclick="setLang('es')">
          <span class="flag-emoji">🇪🇸</span>
          <span class="flag-label">Español</span>
        </button>
        <button class="flag-mini" data-lang="zh" onclick="setLang('zh')">
          <span class="flag-emoji">🇨🇳</span>
          <span class="flag-label">中文</span>
        </button>
        <button class="flag-mini" data-lang="hi" onclick="setLang('hi')">
          <span class="flag-emoji">🇮🇳</span>
          <span class="flag-label">हिन्दी</span>
        </button>
        <button class="flag-mini" data-lang="ar" onclick="setLang('ar')">
          <span class="flag-emoji">🇸🇦</span>
          <span class="flag-label">العربية</span>
        </button>
        <button class="flag-mini" data-lang="pt" onclick="setLang('pt')">
          <span class="flag-emoji">🇵🇹</span>
          <span class="flag-label">Português</span>
        </button>
        <button class="flag-mini" data-lang="ru" onclick="setLang('ru')">
          <span class="flag-emoji">🇷🇺</span>
          <span class="flag-label">Русский</span>
        </button>
        <button class="flag-mini" data-lang="bn" onclick="setLang('bn')">
          <span class="flag-emoji">🇧🇩</span>
          <span class="flag-label">বাংলা</span>
        </button>
        <button class="flag-mini" data-lang="id" onclick="setLang('id')">
          <span class="flag-emoji">🇮🇩</span>
          <span class="flag-label">Bahasa Indonesia</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ═══ CONTENU PRINCIPAL ═══ -->
  <div id="mainContent" style="display: none;">
    <div class="container">

      <!-- EN-TÊTE -->
      <header class="header">
        <div class="logo">
          <span class="bot-icon">🤖</span>
          <h1><%= botName || 'DENTSU MD V9' %></h1>
        </div>
        <span class="badge">by <%= devName || 'NatsuTech' %></span>
      </header>

      <main>
        <!-- CARTE DE CONNEXION -->
        <section class="card connect-card">
          <h2 data-i18n="h2_connect">📱 Connecter WhatsApp</h2>
          <p class="subtitle" data-i18n="subtitle_connect">
            Entre ton numéro avec le code pays pour obtenir ton code de jumelage
          </p>

          <form id="pairForm" novalidate>
            <div class="input-group">
              <input 
                type="tel" 
                id="number" 
                placeholder="242065121108" 
                required
                autocomplete="tel"
                aria-label="Numéro de téléphone"
                inputmode="numeric"
                pattern="[0-9]*"
              >
              <button type="submit" id="pairBtn" data-i18n="btn_pair">
                📲 Obtenir mon code
              </button>
            </div>
            <p class="hint" data-i18n="hint">
              ⚠️ Inclure le code pays sans le + (ex: <strong>242</strong>XXXXXXXX)
            </p>
          </form>

          <!-- RÉSULTAT -->
          <div id="result" class="result" style="display: none;"></div>

          <!-- AFFICHAGE DU CODE -->
          <div id="codeDisplay" style="display: none;">
            <div class="code-container">
              <p data-i18n="code_label">🔑 Ton code de jumelage :</p>
              <div class="code-box">
                <span id="codeValue">000-000-000</span>
                <button id="copyBtn" data-i18n="btn_copy">📋 Copier le code</button>
              </div>
              <p class="warning" data-i18n="warning">
                ⏱️ Le code expire dans <strong>60 secondes</strong> — entre-le rapidement !
              </p>
            </div>
          </div>

          <!-- ÉTAPES -->
          <div id="steps" style="display: none;">
            <div class="steps-container">
              <p class="steps-title" data-i18n="steps_title">
                📋 Comment entrer le code dans WhatsApp :
              </p>
              <ol id="stepsList"></ol>
            </div>
          </div>
        </section>

        <!-- LIENS SOCIAUX -->
        <section class="card social-card">
          <div class="social-links">
            <a href="<%= channelLink || '#' %>" target="_blank" rel="noopener noreferrer" class="social-btn channel">
              <span>📢</span> <span data-i18n="social_channel">Canal</span>
            </a>
            <a href="<%= groupLink || '#' %>" target="_blank" rel="noopener noreferrer" class="social-btn group">
              <span>👥</span> <span data-i18n="social_group">Groupe</span>
            </a>
            <a href="<%= telegram || '#' %>" target="_blank" rel="noopener noreferrer" class="social-btn telegram">
              <span>✈️</span> <span>Télégram</span>
            </a>
          </div>
        </section>
      </main>

      <!-- PIED DE PAGE -->
      <footer class="footer">
        <p data-i18n="footer">© 2025 NatsuTech • Tous droits réservés</p>
      </footer>
    </div>
  </div>

